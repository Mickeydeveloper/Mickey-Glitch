{
  "name": "Mickey-Glitch",
  "version": "1.0.0",
  "description": "WhatsApp Bot",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "start:optimized": "node --max-old-space-size=512 --optimize-for-size --gc-interval=100 --max-semi-space-size=128 index.js",
    "cleanup": "node cleanup.js",
    "reset-session": "node reset-session.js",
    "start:clean": "npm run cleanup && npm run start:optimized",
    "start:fresh": "npm run reset-session && npm run start:optimized",
    "start:stable": "node --max-old-space-size=1024 --optimize-for-size --gc-interval=50 --max-semi-space-size=256 server.js",
    "install:panel": "npm install --legacy-peer-deps",
    "install:force": "npm install --force",
    "test": "echo \"Error: no test specified\" && exit 1",
    "docker:build": "docker build -t docker run -e SESSION_ID=$SESSION_ID knightbot"
  },
  "keywords": [
    "whatsapp-bot"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@hapi/boom": "^10.0.1",
    "@types/node": "^25.5.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "awesome-phonenumber": "^7.8.0",
    "axios": "^1.13.6",
    "acrcloud": "^1.4.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "cookie": "^1.1.1",
    "dotenv": "^17.3.1",
    "events": "^3.3.0",
    "file-type": "^21.3.3",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.4",
    "gtts": "^0.2.1",
    "human-readable": "^0.2.1",
    "jimp": "^1.6.0",
    "jsdom": "^29.0.0",
    "libphonenumber-js": "^1.12.40",
    "libsignal": "^2.0.1",
    "link-preview-js": "^3.0.0",
    "moment-timezone": "^0.6.0",
    "mumaker": "^2.0.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "node-id3": "^0.2.9",
    "node-webpmux": "^3.2.1",
