    "translate-google-api": "^1.0.4",
    "ws": "^8.19.0",
    "yargs": "^18.0.0",
    "yargs-parser": "^22.0.0",
    "youtube-yts": "^2.0.0",
    "youtubedl-core": "^4.11.7",
    "yt-search": "^2.13.1",
